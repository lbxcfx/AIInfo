# Runtime
APP_ENV=development
APP_NAME=ai-intel-radar
APP_HOST=127.0.0.1
APP_PORT=8000
WEB_PORT=3000
LOG_LEVEL=INFO

# Database
POSTGRES_DB=ai_intel_radar
POSTGRES_USER=ai_intel
POSTGRES_PASSWORD=ai_intel_dev_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://ai_intel:ai_intel_dev_password@127.0.0.1:5432/ai_intel_radar
DATABASE_SYNC_URL=postgresql+psycopg://ai_intel:ai_intel_dev_password@127.0.0.1:5432/ai_intel_radar

# Redis / Queue
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# Search
MEILISEARCH_URL=http://127.0.0.1:7700
MEILISEARCH_MASTER_KEY=change_me_in_production
MEILISEARCH_INDEX_ITEMS=ai_items
MEILISEARCH_INDEX_EVENTS=ai_events

# Zhipu / BigModel GLM
ZAI_API_KEY=
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
BIGMODEL_TIMEOUT_SECONDS=60
BIGMODEL_MAX_RETRIES=3

# LLM routing
LLM_PROVIDER=bigmodel
LLM_MODEL_RELEVANCE=glm-4.5-air
LLM_MODEL_TRANSLATION=glm-4.5-air
LLM_MODEL_SUMMARY=glm-5-turbo
LLM_MODEL_CLASSIFICATION=glm-5-turbo
LLM_MODEL_ENTITY=glm-5-turbo
LLM_MODEL_SCORING=glm-5-turbo
LLM_MODEL_AUDIT=glm-5.1

# Generation parameters
LLM_TEMPERATURE_CLASSIFICATION=0.2
LLM_TEMPERATURE_SUMMARY=0.3
LLM_TEMPERATURE_SCORING=0.2
LLM_MAX_TOKENS_RELEVANCE=1024
LLM_MAX_TOKENS_SUMMARY=3000
LLM_MAX_TOKENS_SCORING=3000

# Embedding
EMBEDDING_PROVIDER=bigmodel
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_INPUT_TOKENS=3072

# Crawling
CRAWL_USER_AGENT=AIIntelRadarBot/0.1 (+local-dev)
CRAWL_TIMEOUT_SECONDS=30
CRAWL_MAX_RETRIES=3
CRAWL_CONCURRENCY=8
CRAWL_SAVE_RAW_HTML=true
RAW_HTML_DIR=./data/raw_html
GITHUB_TOKEN=
X_BEARER_TOKEN=

# Ranking defaults
DEFAULT_RULE_VERSION=v1
FEATURED_DEFAULT_LIMIT=20
API_MAX_LIMIT=100
DAILY_REPORT_TIMEZONE=Asia/Shanghai
DAILY_REPORT_HOUR=8

# Security
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
API_AUTH_ENABLED=false
API_RATE_LIMIT_PER_MINUTE=120

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
